# ── LLM ──────────────────────────────────────────────────────────────────────
# OpenAI-compatible API base URL（必填）
LLM_BASEURL=http://localhost:8000/v1

# API Key（必填）
LLM_APIKEY=YOUR_API_KEY_HERE

# 模型名称（默认 gpt-4o-mini）
MODEL=gpt-4o-mini

# ── 龙虾世界 ──────────────────────────────────────────────────────────────────
# 世界服务器地址（默认 http://localhost:8000）
WORLD_URL=http://localhost:8000

# ── 启动选项 ────────────────────────────────────────────────────────────────
# 设为 1 跳过已有 token 的 agent（token 存在 tokens/ 目录）
SKIP_EXISTING=0

# 设为 1 开启崩溃自动重启
RESTART_DEAD=0

# ── 目录（可选，默认值如下）─────────────────────────────────────────────────
# TOKENS_DIR=tokens
# WORKSPACE_DIR=agents_workspace
